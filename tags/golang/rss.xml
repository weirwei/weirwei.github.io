<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Golang on 浩雨未倾</title><link>http://weirwei.cn/tags/golang/</link><description>Recent content in Golang on 浩雨未倾</description><generator>Hugo</generator><language>zh-CN</language><lastBuildDate>Fri, 26 Jul 2024 15:35:20 +0800</lastBuildDate><atom:link href="http://weirwei.cn/tags/golang/rss.xml" rel="self" type="application/rss+xml"/><item><title>Golang 的 docker 部署流程</title><link>http://weirwei.cn/practical/docker_deploy_golang/</link><pubDate>Fri, 26 Jul 2024 15:35:20 +0800</pubDate><guid>http://weirwei.cn/practical/docker_deploy_golang/</guid><description>&lt;blockquote>
